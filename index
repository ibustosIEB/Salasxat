<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MentorChat</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap');

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:       #0f1117;
    --surface:  #1a1d27;
    --surface2: #22263a;
    --border:   #2e334d;
    --accent:   #6c8cff;
    --accent2:  #a78bfa;
    --green:    #34d399;
    --red:      #f87171;
    --text:     #e2e8f0;
    --muted:    #64748b;
    --radius:   12px;
  }

  body {
    font-family: 'Inter', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* ── HEADER ── */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 24px;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    position: sticky; top: 0; z-index: 100;
  }
  .logo { display: flex; align-items: center; gap: 10px; }
  .logo-icon {
    width: 32px; height: 32px; border-radius: 8px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    display: grid; place-items: center; font-size: 16px;
  }
  .logo-text { font-weight: 700; font-size: 1rem; letter-spacing: -0.02em; }
  .logo-sub { font-size: .7rem; color: var(--muted); font-weight: 400; }

  #btn-admin-access {
    font-size: .75rem; font-family: 'JetBrains Mono', monospace;
    color: var(--muted); background: none; border: 1px solid var(--border);
    border-radius: 6px; padding: 5px 10px; cursor: pointer;
    transition: color .2s, border-color .2s;
  }
  #btn-admin-access:hover { color: var(--accent); border-color: var(--accent); }

  /* ── SCREENS ── */
  .screen { display: none; }
  .screen.active { display: flex; flex-direction: column; flex: 1; }

  /* ── LOBBY ── */
  #screen-lobby {
    align-items: center;
    padding: 48px 24px;
  }
  .lobby-title {
    font-size: 1.6rem; font-weight: 700; text-align: center;
    letter-spacing: -0.03em; margin-bottom: 6px;
  }
  .lobby-sub { color: var(--muted); text-align: center; margin-bottom: 36px; font-size: .9rem; }
  .rooms-grid {
    display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 16px; width: 100%; max-width: 900px;
  }
  .room-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 20px;
    cursor: pointer; transition: border-color .2s, transform .15s;
  }
  .room-card:hover { border-color: var(--accent); transform: translateY(-2px); }
  .room-card-name { font-weight: 600; margin-bottom: 4px; }
  .room-card-desc { font-size: .8rem; color: var(--muted); margin-bottom: 14px; min-height: 36px; }
  .room-card-footer {
    display: flex; align-items: center; justify-content: space-between;
    font-size: .75rem; color: var(--muted);
  }
  .lock-icon { font-size: .85rem; }
  .join-btn {
    font-size: .75rem; font-weight: 600;
    background: var(--accent); color: #fff;
    border: none; border-radius: 6px; padding: 5px 12px;
    cursor: pointer; transition: opacity .2s;
  }
  .join-btn:hover { opacity: .85; }
  .empty-state {
    text-align: center; color: var(--muted); margin-top: 60px;
    font-size: .9rem; line-height: 1.6;
  }
  .empty-state .big { font-size: 2.5rem; margin-bottom: 8px; }

  /* ── MODAL PASSWORD ── */
  .modal-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,.65); backdrop-filter: blur(4px);
    z-index: 200; align-items: center; justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 16px; padding: 28px; width: 100%; max-width: 360px;
    animation: pop .2s ease;
  }
  @keyframes pop { from { transform: scale(.94); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .modal h2 { font-size: 1.1rem; margin-bottom: 4px; }
  .modal p { font-size: .8rem; color: var(--muted); margin-bottom: 18px; }
  .field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 14px; }
  .field label { font-size: .78rem; font-weight: 500; color: var(--muted); }
  .field input, .field textarea, .field select {
    background: var(--bg); border: 1px solid var(--border);
    border-radius: 8px; padding: 9px 12px; color: var(--text);
    font-family: 'Inter', sans-serif; font-size: .88rem;
    transition: border-color .2s; outline: none;
  }
  .field input:focus, .field textarea:focus { border-color: var(--accent); }
  .field textarea { resize: vertical; min-height: 70px; }
  .modal-actions { display: flex; gap: 8px; justify-content: flex-end; margin-top: 18px; }
  .btn-cancel {
    background: none; border: 1px solid var(--border); color: var(--muted);
    border-radius: 8px; padding: 8px 16px; cursor: pointer; font-size: .85rem;
    transition: color .2s, border-color .2s;
  }
  .btn-cancel:hover { color: var(--text); border-color: var(--text); }
  .btn-confirm {
    background: var(--accent); color: #fff; border: none;
    border-radius: 8px; padding: 8px 18px; cursor: pointer; font-size: .85rem; font-weight: 600;
    transition: opacity .2s;
  }
  .btn-confirm:hover { opacity: .85; }
  .btn-danger {
    background: var(--red); color: #fff; border: none;
    border-radius: 8px; padding: 8px 18px; cursor: pointer; font-size: .85rem; font-weight: 600;
  }
  .error-msg { color: var(--red); font-size: .78rem; margin-top: 4px; display: none; }
  .error-msg.show { display: block; }

  /* ── ADMIN PANEL ── */
  #screen-admin {
    padding: 32px 24px;
    max-width: 800px; margin: 0 auto; width: 100%;
  }
  .admin-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 28px;
  }
  .admin-title { font-size: 1.3rem; font-weight: 700; }
  .admin-badge {
    font-size: .7rem; font-family: 'JetBrains Mono', monospace;
    color: var(--green); border: 1px solid var(--green);
    border-radius: 20px; padding: 3px 10px;
  }
  .btn-primary {
    background: var(--accent); color: #fff; border: none;
    border-radius: 8px; padding: 9px 18px; cursor: pointer; font-size: .85rem; font-weight: 600;
    transition: opacity .2s; display: flex; align-items: center; gap: 6px;
  }
  .btn-primary:hover { opacity: .85; }
  .admin-rooms { display: flex; flex-direction: column; gap: 12px; }
  .admin-room-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 16px 20px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .admin-room-info .name { font-weight: 600; font-size: .95rem; }
  .admin-room-info .meta {
    font-size: .75rem; color: var(--muted); margin-top: 2px;
    font-family: 'JetBrains Mono', monospace;
  }
  .admin-room-actions { display: flex; gap: 8px; flex-shrink: 0; }
  .btn-icon {
    background: var(--surface2); border: 1px solid var(--border); color: var(--text);
    border-radius: 7px; padding: 6px 10px; cursor: pointer; font-size: .8rem;
    transition: background .2s;
  }
  .btn-icon:hover { background: var(--border); }
  .btn-icon.red:hover { background: #3d1f1f; border-color: var(--red); color: var(--red); }
  .admin-empty { color: var(--muted); text-align: center; padding: 40px 0; font-size: .9rem; }

  /* ── CHAT ── */
  #screen-chat {
    height: calc(100vh - 57px);
    flex-direction: row;
  }
  .chat-sidebar {
    width: 220px; flex-shrink: 0;
    background: var(--surface); border-right: 1px solid var(--border);
    display: flex; flex-direction: column; padding: 16px 12px;
    gap: 4px;
  }
  .sidebar-title { font-size: .7rem; font-weight: 600; color: var(--muted); letter-spacing: .08em; text-transform: uppercase; margin-bottom: 8px; padding: 0 8px; }
  .sidebar-room-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 10px; border-radius: 8px; cursor: pointer;
    font-size: .85rem; font-weight: 500; color: var(--muted);
    transition: background .15s, color .15s; border: none; background: none; text-align: left;
    width: 100%;
  }
  .sidebar-room-btn:hover { background: var(--surface2); color: var(--text); }
  .sidebar-room-btn.active { background: var(--accent); color: #fff; }
  .sidebar-room-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--green); flex-shrink: 0; }
  .sidebar-footer {
    margin-top: auto;
  }
  .btn-leave {
    width: 100%; background: none; border: 1px solid var(--border);
    color: var(--muted); border-radius: 8px; padding: 8px; cursor: pointer;
    font-size: .78rem; transition: color .2s, border-color .2s;
  }
  .btn-leave:hover { color: var(--red); border-color: var(--red); }

  .chat-main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
  .chat-topbar {
    padding: 14px 20px; background: var(--surface); border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .chat-room-name { font-weight: 600; }
  .chat-room-desc { font-size: .78rem; color: var(--muted); margin-top: 2px; }
  .msg-count { font-size: .72rem; font-family: 'JetBrains Mono', monospace; color: var(--muted); }

  .messages-area {
    flex: 1; overflow-y: auto; padding: 20px;
    display: flex; flex-direction: column; gap: 10px;
  }
  .messages-area::-webkit-scrollbar { width: 5px; }
  .messages-area::-webkit-scrollbar-track { background: transparent; }
  .messages-area::-webkit-scrollbar-thumb { background: var(--border); border-radius: 10px; }

  .msg {
    max-width: 75%; display: flex; flex-direction: column; gap: 3px;
  }
  .msg.mine { align-self: flex-end; align-items: flex-end; }
  .msg.theirs { align-self: flex-start; align-items: flex-start; }
  .msg-sender { font-size: .7rem; color: var(--muted); font-weight: 500; padding: 0 4px; }
  .msg-bubble {
    padding: 9px 14px; border-radius: 14px;
    font-size: .88rem; line-height: 1.5; word-break: break-word;
  }
  .msg.mine .msg-bubble {
    background: var(--accent); color: #fff;
    border-radius: 14px 14px 4px 14px;
  }
  .msg.theirs .msg-bubble {
    background: var(--surface); border: 1px solid var(--border);
    color: var(--text); border-radius: 14px 14px 14px 4px;
  }
  .msg-time { font-size: .65rem; color: var(--muted); padding: 0 4px; }
  .no-msgs { text-align: center; color: var(--muted); margin: auto; font-size: .85rem; }

  .chat-input-area {
    padding: 14px 20px; border-top: 1px solid var(--border);
    display: flex; gap: 10px; align-items: flex-end;
    background: var(--surface);
  }
  .name-tag {
    font-size: .72rem; color: var(--accent); font-weight: 600;
    font-family: 'JetBrains Mono', monospace; margin-bottom: 4px;
  }
  .chat-input-wrap { flex: 1; }
  #msg-input {
    width: 100%; background: var(--bg); border: 1px solid var(--border);
    border-radius: 10px; padding: 10px 14px; color: var(--text);
    font-family: 'Inter', sans-serif; font-size: .88rem;
    resize: none; outline: none; max-height: 120px; transition: border-color .2s;
  }
  #msg-input:focus { border-color: var(--accent); }
  #btn-send {
    background: var(--accent); color: #fff; border: none;
    border-radius: 10px; padding: 10px 16px; cursor: pointer; font-size: 1rem;
    transition: opacity .2s; align-self: flex-end;
  }
  #btn-send:hover { opacity: .85; }

  /* Toast */
  #toast {
    position: fixed; bottom: 24px; right: 24px;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 10px; padding: 10px 18px; font-size: .82rem;
    opacity: 0; transform: translateY(8px);
    transition: opacity .25s, transform .25s; z-index: 999;
    pointer-events: none;
  }
  #toast.show { opacity: 1; transform: translateY(0); }

  @media (max-width: 600px) {
    .chat-sidebar { display: none; }
    #screen-chat { flex-direction: column; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="logo">
    <div class="logo-icon">💬</div>
    <div>
      <div class="logo-text">MentorChat</div>
      <div class="logo-sub">Salas privadas de mentors</div>
    </div>
  </div>
  <button id="btn-admin-access">⚙ Admin</button>
</header>

<!-- ══════════════════════════════ SCREENS ══════════════════════════════ -->

<!-- LOBBY -->
<div id="screen-lobby" class="screen active">
  <div style="max-width:900px;width:100%;margin:0 auto;padding:48px 24px;">
    <div class="lobby-title">Salas disponibles</div>
    <div class="lobby-sub">Selecciona una sala e introduce la contraseña para acceder.</div>
    <div id="rooms-grid" class="rooms-grid"></div>
    <div id="empty-state" class="empty-state" style="display:none">
      <div class="big">🔒</div>
      <div>Todavía no hay salas creadas.<br>El administrador puede crear salas desde el panel admin.</div>
    </div>
  </div>
</div>

<!-- ADMIN -->
<div id="screen-admin" class="screen">
  <div class="admin-header">
    <div>
      <div class="admin-title">Panel de administración</div>
    </div>
    <div style="display:flex;gap:10px;align-items:center">
      <span class="admin-badge">ADMIN</span>
      <button class="btn-primary" id="btn-new-room">+ Nueva sala</button>
      <button class="btn-icon" id="btn-exit-admin">← Salir</button>
    </div>
  </div>
  <div id="admin-rooms" class="admin-rooms"></div>
  <div id="admin-empty" class="admin-empty">No hay salas. Crea la primera.</div>
</div>

<!-- CHAT -->
<div id="screen-chat" class="screen">
  <div class="chat-sidebar">
    <div class="sidebar-title">Salas</div>
    <div id="sidebar-rooms"></div>
    <div class="sidebar-footer">
      <button class="btn-leave" id="btn-leave">← Salir del chat</button>
    </div>
  </div>
  <div class="chat-main">
    <div class="chat-topbar">
      <div>
        <div class="chat-room-name" id="chat-room-name">Sala</div>
        <div class="chat-room-desc" id="chat-room-desc"></div>
      </div>
      <div class="msg-count" id="msg-count"></div>
    </div>
    <div class="messages-area" id="messages-area">
      <div class="no-msgs" id="no-msgs">Sé el primero en escribir ✨</div>
    </div>
    <div class="chat-input-area">
      <div class="chat-input-wrap">
        <div class="name-tag" id="name-tag"></div>
        <textarea id="msg-input" rows="1" placeholder="Escribe un mensaje…"></textarea>
      </div>
      <button id="btn-send">➤</button>
    </div>
  </div>
</div>

<!-- ══════════════════════════════ MODALS ══════════════════════════════ -->

<!-- Modal: Login admin -->
<div class="modal-overlay" id="modal-admin-login">
  <div class="modal">
    <h2>Acceso de administrador</h2>
    <p>Introduce la contraseña maestra para gestionar las salas.</p>
    <div class="field">
      <label>Contraseña maestra</label>
      <input type="password" id="admin-pwd-input" placeholder="••••••••">
      <span class="error-msg" id="admin-pwd-error">Contraseña incorrecta.</span>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="admin-login-cancel">Cancelar</button>
      <button class="btn-confirm" id="admin-login-confirm">Entrar</button>
    </div>
  </div>
</div>

<!-- Modal: Crear sala -->
<div class="modal-overlay" id="modal-create-room">
  <div class="modal">
    <h2>Nueva sala privada</h2>
    <p>Configura los datos de la sala.</p>
    <div class="field">
      <label>Nombre de la sala</label>
      <input type="text" id="room-name-input" placeholder="p.ej. Mentors TFG 2025">
      <span class="error-msg" id="room-name-error">El nombre es obligatorio.</span>
    </div>
    <div class="field">
      <label>Descripción (opcional)</label>
      <textarea id="room-desc-input" placeholder="Breve descripción de la sala…"></textarea>
    </div>
    <div class="field">
      <label>Contraseña de acceso</label>
      <input type="text" id="room-pwd-input" placeholder="Contraseña para los mentors">
      <span class="error-msg" id="room-pwd-error">La contraseña es obligatoria.</span>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="create-room-cancel">Cancelar</button>
      <button class="btn-confirm" id="create-room-confirm">Crear sala</button>
    </div>
  </div>
</div>

<!-- Modal: Cambiar contraseña sala -->
<div class="modal-overlay" id="modal-edit-room">
  <div class="modal">
    <h2>Editar sala</h2>
    <p>Puedes cambiar la contraseña de acceso.</p>
    <div class="field">
      <label>Nueva contraseña</label>
      <input type="text" id="edit-room-pwd-input" placeholder="Nueva contraseña">
      <span class="error-msg" id="edit-room-pwd-error">Introduce una contraseña.</span>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="edit-room-cancel">Cancelar</button>
      <button class="btn-confirm" id="edit-room-confirm">Guardar</button>
    </div>
  </div>
</div>

<!-- Modal: Borrar sala -->
<div class="modal-overlay" id="modal-delete-room">
  <div class="modal">
    <h2>Eliminar sala</h2>
    <p>¿Seguro que quieres eliminar esta sala? Se borrarán todos los mensajes y no se puede deshacer.</p>
    <div class="modal-actions">
      <button class="btn-cancel" id="delete-room-cancel">Cancelar</button>
      <button class="btn-danger" id="delete-room-confirm">Eliminar</button>
    </div>
  </div>
</div>

<!-- Modal: Entrar a sala (contraseña + nombre) -->
<div class="modal-overlay" id="modal-join-room">
  <div class="modal">
    <h2 id="join-room-title">Entrar a la sala</h2>
    <p>Introduce tu nombre y la contraseña de la sala.</p>
    <div class="field">
      <label>Tu nombre</label>
      <input type="text" id="join-name-input" placeholder="Tu nombre o alias">
      <span class="error-msg" id="join-name-error">Indica tu nombre.</span>
    </div>
    <div class="field">
      <label>Contraseña de la sala</label>
      <input type="password" id="join-pwd-input" placeholder="••••••••">
      <span class="error-msg" id="join-pwd-error">Contraseña incorrecta.</span>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" id="join-room-cancel">Cancelar</button>
      <button class="btn-confirm" id="join-room-confirm">Entrar</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div id="toast"></div>

<script>
// ════════════════════════════════════════════
//  CONFIG — cambia esto por tu contraseña admin
// ════════════════════════════════════════════
const ADMIN_PASSWORD = 'mentor2025';

// ════════════════════════════════════════════
//  STATE
// ════════════════════════════════════════════
let state = {
  currentScreen: 'lobby',   // 'lobby' | 'admin' | 'chat'
  currentRoom: null,        // id de la sala activa
  currentUser: '',          // nombre del usuario en el chat
  editingRoomId: null,
  deletingRoomId: null,
  joinTargetId: null,
};

// ════════════════════════════════════════════
//  STORAGE HELPERS
// ════════════════════════════════════════════
function getRooms() {
  return JSON.parse(localStorage.getItem('mc_rooms') || '[]');
}
function saveRooms(rooms) {
  localStorage.setItem('mc_rooms', JSON.stringify(rooms));
}
function getMessages(roomId) {
  return JSON.parse(localStorage.getItem(`mc_msgs_${roomId}`) || '[]');
}
function saveMessages(roomId, msgs) {
  localStorage.setItem(`mc_msgs_${roomId}`, JSON.stringify(msgs));
}
function genId() {
  return Date.now().toString(36) + Math.random().toString(36).slice(2, 6);
}

// ════════════════════════════════════════════
//  SCREEN MANAGEMENT
// ════════════════════════════════════════════
function showScreen(name) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + name).classList.add('active');
  state.currentScreen = name;
}

// ════════════════════════════════════════════
//  TOAST
// ════════════════════════════════════════════
let toastTimer;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

// ════════════════════════════════════════════
//  MODALS
// ════════════════════════════════════════════
function openModal(id) { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }
function showErr(id, show) {
  document.getElementById(id).classList.toggle('show', show);
}

// ════════════════════════════════════════════
//  LOBBY
// ════════════════════════════════════════════
function renderLobby() {
  const grid = document.getElementById('rooms-grid');
  const empty = document.getElementById('empty-state');
  const rooms = getRooms();
  grid.innerHTML = '';
  if (!rooms.length) {
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';
  rooms.forEach(room => {
    const msgs = getMessages(room.id);
    const card = document.createElement('div');
    card.className = 'room-card';
    card.innerHTML = `
      <div class="room-card-name">${esc(room.name)}</div>
      <div class="room-card-desc">${esc(room.desc || 'Sin descripción')}</div>
      <div class="room-card-footer">
        <span><span class="lock-icon">🔒</span> Privada · ${msgs.length} msgs</span>
        <button class="join-btn">Entrar</button>
      </div>`;
    card.querySelector('.join-btn').addEventListener('click', () => openJoinModal(room.id));
    grid.appendChild(card);
  });
}

// ════════════════════════════════════════════
//  JOIN MODAL
// ════════════════════════════════════════════
function openJoinModal(roomId) {
  state.joinTargetId = roomId;
  const room = getRooms().find(r => r.id === roomId);
  document.getElementById('join-room-title').textContent = '🔒 ' + room.name;
  document.getElementById('join-name-input').value = '';
  document.getElementById('join-pwd-input').value = '';
  showErr('join-name-error', false);
  showErr('join-pwd-error', false);
  // Pre-fill saved name
  const saved = localStorage.getItem('mc_last_name');
  if (saved) document.getElementById('join-name-input').value = saved;
  openModal('modal-join-room');
  setTimeout(() => document.getElementById('join-name-input').focus(), 100);
}

document.getElementById('join-room-confirm').addEventListener('click', () => {
  const name = document.getElementById('join-name-input').value.trim();
  const pwd  = document.getElementById('join-pwd-input').value.trim();
  const room = getRooms().find(r => r.id === state.joinTargetId);
  let ok = true;
  if (!name) { showErr('join-name-error', true); ok = false; }
  else showErr('join-name-error', false);
  if (!pwd || pwd !== room.password) { showErr('join-pwd-error', true); ok = false; }
  else showErr('join-pwd-error', false);
  if (!ok) return;
  localStorage.setItem('mc_last_name', name);
  closeModal('modal-join-room');
  enterChat(state.joinTargetId, name);
});
document.getElementById('join-room-cancel').addEventListener('click', () => closeModal('modal-join-room'));

// ════════════════════════════════════════════
//  CHAT
// ════════════════════════════════════════════
let pollInterval = null;

function enterChat(roomId, userName) {
  state.currentRoom = roomId;
  state.currentUser = userName;
  renderSidebar();
  renderChatRoom(roomId);
  showScreen('chat');
  startPolling();
}

function renderSidebar() {
  const rooms = getRooms();
  const container = document.getElementById('sidebar-rooms');
  container.innerHTML = '';
  rooms.forEach(room => {
    const btn = document.createElement('button');
    btn.className = 'sidebar-room-btn' + (room.id === state.currentRoom ? ' active' : '');
    btn.innerHTML = `<span class="sidebar-room-dot"></span>${esc(room.name)}`;
    btn.addEventListener('click', () => openJoinModal(room.id));
    container.appendChild(btn);
  });
}

function renderChatRoom(roomId) {
  const room = getRooms().find(r => r.id === roomId);
  if (!room) { showScreen('lobby'); renderLobby(); return; }
  document.getElementById('chat-room-name').textContent = room.name;
  document.getElementById('chat-room-desc').textContent = room.desc || '';
  document.getElementById('name-tag').textContent = '@ ' + state.currentUser;
  renderMessages(roomId);
}

function renderMessages(roomId) {
  const area = document.getElementById('messages-area');
  const noMsgs = document.getElementById('no-msgs');
  const msgs = getMessages(roomId);
  document.getElementById('msg-count').textContent = msgs.length + ' msgs';

  // Remove existing msgs
  area.querySelectorAll('.msg').forEach(e => e.remove());

  if (!msgs.length) {
    noMsgs.style.display = 'block';
    return;
  }
  noMsgs.style.display = 'none';

  const wasAtBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 60;

  msgs.forEach(msg => {
    const isMine = msg.sender === state.currentUser;
    const div = document.createElement('div');
    div.className = 'msg ' + (isMine ? 'mine' : 'theirs');
    div.dataset.id = msg.id;
    div.innerHTML = `
      ${!isMine ? `<div class="msg-sender">${esc(msg.sender)}</div>` : ''}
      <div class="msg-bubble">${esc(msg.text)}</div>
      <div class="msg-time">${formatTime(msg.ts)}</div>`;
    area.appendChild(div);
  });

  if (wasAtBottom || msgs.length === 1) {
    area.scrollTop = area.scrollHeight;
  }
}

function startPolling() {
  if (pollInterval) clearInterval(pollInterval);
  pollInterval = setInterval(() => {
    if (state.currentScreen === 'chat') renderMessages(state.currentRoom);
  }, 1500);
}

function stopPolling() {
  if (pollInterval) clearInterval(pollInterval);
  pollInterval = null;
}

// Send message
function sendMessage() {
  const input = document.getElementById('msg-input');
  const text = input.value.trim();
  if (!text || !state.currentRoom) return;
  const msgs = getMessages(state.currentRoom);
  msgs.push({ id: genId(), sender: state.currentUser, text, ts: Date.now() });
  saveMessages(state.currentRoom, msgs);
  input.value = '';
  input.style.height = 'auto';
  renderMessages(state.currentRoom);
}

document.getElementById('btn-send').addEventListener('click', sendMessage);
document.getElementById('msg-input').addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});
document.getElementById('msg-input').addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 120) + 'px';
});

document.getElementById('btn-leave').addEventListener('click', () => {
  stopPolling();
  state.currentRoom = null;
  state.currentUser = '';
  showScreen('lobby');
  renderLobby();
});

// ════════════════════════════════════════════
//  ADMIN
// ════════════════════════════════════════════
document.getElementById('btn-admin-access').addEventListener('click', () => {
  document.getElementById('admin-pwd-input').value = '';
  showErr('admin-pwd-error', false);
  openModal('modal-admin-login');
  setTimeout(() => document.getElementById('admin-pwd-input').focus(), 100);
});

document.getElementById('admin-login-confirm').addEventListener('click', () => {
  const pwd = document.getElementById('admin-pwd-input').value;
  if (pwd !== ADMIN_PASSWORD) { showErr('admin-pwd-error', true); return; }
  closeModal('modal-admin-login');
  stopPolling();
  renderAdmin();
  showScreen('admin');
});
document.getElementById('admin-login-cancel').addEventListener('click', () => closeModal('modal-admin-login'));
document.getElementById('admin-pwd-input').addEventListener('keydown', e => {
  if (e.key === 'Enter') document.getElementById('admin-login-confirm').click();
});

document.getElementById('btn-exit-admin').addEventListener('click', () => {
  showScreen('lobby');
  renderLobby();
});

function renderAdmin() {
  const rooms = getRooms();
  const container = document.getElementById('admin-rooms');
  const empty = document.getElementById('admin-empty');
  container.innerHTML = '';
  if (!rooms.length) { empty.style.display = 'block'; return; }
  empty.style.display = 'none';
  rooms.forEach(room => {
    const msgs = getMessages(room.id);
    const card = document.createElement('div');
    card.className = 'admin-room-card';
    card.innerHTML = `
      <div class="admin-room-info">
        <div class="name">${esc(room.name)}</div>
        <div class="meta">🔑 ${esc(room.password)} · ${msgs.length} mensajes</div>
        ${room.desc ? `<div style="font-size:.78rem;color:var(--muted);margin-top:2px">${esc(room.desc)}</div>` : ''}
      </div>
      <div class="admin-room-actions">
        <button class="btn-icon" data-edit="${room.id}">✏️ Editar</button>
        <button class="btn-icon red" data-del="${room.id}">🗑 Eliminar</button>
      </div>`;
    card.querySelector('[data-edit]').addEventListener('click', () => openEditModal(room.id));
    card.querySelector('[data-del]').addEventListener('click', () => openDeleteModal(room.id));
    container.appendChild(card);
  });
}

// Create room
document.getElementById('btn-new-room').addEventListener('click', () => {
  document.getElementById('room-name-input').value = '';
  document.getElementById('room-desc-input').value = '';
  document.getElementById('room-pwd-input').value = '';
  showErr('room-name-error', false);
  showErr('room-pwd-error', false);
  openModal('modal-create-room');
  setTimeout(() => document.getElementById('room-name-input').focus(), 100);
});
document.getElementById('create-room-cancel').addEventListener('click', () => closeModal('modal-create-room'));
document.getElementById('create-room-confirm').addEventListener('click', () => {
  const name = document.getElementById('room-name-input').value.trim();
  const desc = document.getElementById('room-desc-input').value.trim();
  const pwd  = document.getElementById('room-pwd-input').value.trim();
  let ok = true;
  if (!name) { showErr('room-name-error', true); ok = false; } else showErr('room-name-error', false);
  if (!pwd)  { showErr('room-pwd-error', true); ok = false; }  else showErr('room-pwd-error', false);
  if (!ok) return;
  const rooms = getRooms();
  rooms.push({ id: genId(), name, desc, password: pwd, createdAt: Date.now() });
  saveRooms(rooms);
  closeModal('modal-create-room');
  renderAdmin();
  toast('✅ Sala "' + name + '" creada.');
});

// Edit room
function openEditModal(roomId) {
  state.editingRoomId = roomId;
  const room = getRooms().find(r => r.id === roomId);
  document.getElementById('edit-room-pwd-input').value = room.password;
  showErr('edit-room-pwd-error', false);
  openModal('modal-edit-room');
  setTimeout(() => document.getElementById('edit-room-pwd-input').focus(), 100);
}
document.getElementById('edit-room-cancel').addEventListener('click', () => closeModal('modal-edit-room'));
document.getElementById('edit-room-confirm').addEventListener('click', () => {
  const pwd = document.getElementById('edit-room-pwd-input').value.trim();
  if (!pwd) { showErr('edit-room-pwd-error', true); return; }
  const rooms = getRooms();
  const idx = rooms.findIndex(r => r.id === state.editingRoomId);
  if (idx > -1) { rooms[idx].password = pwd; saveRooms(rooms); }
  closeModal('modal-edit-room');
  renderAdmin();
  toast('🔑 Contraseña actualizada.');
});

// Delete room
function openDeleteModal(roomId) {
  state.deletingRoomId = roomId;
  openModal('modal-delete-room');
}
document.getElementById('delete-room-cancel').addEventListener('click', () => closeModal('modal-delete-room'));
document.getElementById('delete-room-confirm').addEventListener('click', () => {
  const rooms = getRooms().filter(r => r.id !== state.deletingRoomId);
  localStorage.removeItem(`mc_msgs_${state.deletingRoomId}`);
  saveRooms(rooms);
  closeModal('modal-delete-room');
  renderAdmin();
  toast('🗑 Sala eliminada.');
});

// ════════════════════════════════════════════
//  UTILS
// ════════════════════════════════════════════
function esc(str) {
  return String(str)
    .replace(/&/g,'&amp;').replace(/</g,'&lt;')
    .replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function formatTime(ts) {
  const d = new Date(ts);
  return d.toLocaleTimeString('es', { hour:'2-digit', minute:'2-digit' }) +
    ' · ' + d.toLocaleDateString('es', { day:'2-digit', month:'short' });
}

// Close modals clicking outside
document.querySelectorAll('.modal-overlay').forEach(overlay => {
  overlay.addEventListener('click', e => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
});

// ════════════════════════════════════════════
//  INIT
// ════════════════════════════════════════════
renderLobby();
</script>
</body>
</html>
